                display(HTML(f'<div style="padding: 5px; background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; border-radius: 3px; margin: 2px 0;">✅ {issue_key}: Updated successfully</div>'))
            else:
                failure_count += 1
                display(HTML(f'<div style="padding: 5px; background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; border-radius: 3px; margin: 2px 0;">❌ {issue_key}: {error}</div>'))
        
        # Final summary
        display(HTML('<h3>Summary:</h3>'))
        display(HTML(f'<div style="padding: 10px; background-color: #e7f3ff; border: 1px solid #bee5eb; color: #0c5460; border-radius: 5px;">✅ Successfully Updated: <strong>{success_count}</strong><br>❌ Failed to Update: <strong>{failure_count}</strong></div>'))

